{
  "name": "sesli-oda",
  "version": "1.0.17",
  "description": "Arkadas grubu icin sesli sohbet ve ekran paylasimi uygulamasi.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "livekit-client": "^2.5.0",
    "lottie-web": "^5.13.0"
  },
  "build": {
    "appId": "com.metin.sesliodaapp",
    "productName": "Funnel Talk",
    "publish": {
      "provider": "github",
      "owner": "metinncetinn",
      "repo": "funnel-talk"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "icon.ico",
      "renderer/**/*",
      "node_modules/**/*",
      "!dist"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true
    }
  }
}
